{
  "app": {
    "name": "ResQ",
    "subtitle": "Smart First Aid Case",
    "host": "0.0.0.0",
    "port": 8080,
    "kiosk": true
  },
  "logging": {
    "file": "logs/resq.log"
  },
  "display": {
    "native_width": 1280,
    "native_height": 720,
    "kiosk_width": 1280,
    "kiosk_height": 720,
    "content_width": 720,
    "content_height": 1280,
    "orientation": "portrait",
    "rotation_degrees": 90
  },
  "hardware": {
    "mode": "simulated",
    "buttons": {
      "yes": ["y", "s"],
      "no": ["n"],
      "back": ["Escape", "Backspace"],
      "repeat_audio": ["r"],
      "home_emergency": [" ", "h"]
    }
  }
}
